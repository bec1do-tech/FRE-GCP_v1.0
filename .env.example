# ─────────────────────────────────────────────────────────────────────────────
# FRE GCP v1.0  —  Environment Variables
# Copy to .env and fill in your values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

#--- Github token with repo access, needed for auto-updating the README with new features and docs
GITHUB_TOKEN=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
# ── Google Cloud Platform ─────────────────────────────────────────────────────
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1

# Google API Key (for Gemini API, local dev without ADC)
GOOGLE_API_KEY=AIza...

# Path to your downloaded service-account JSON key (local dev only).
# Leave empty on Cloud Run / GKE — workload identity is used instead.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Cloud Storage ─────────────────────────────────────────────────────────────
# The GCS bucket that holds all raw documents (10 TB source-of-truth store)
GCS_BUCKET=your-document-bucket
GCS_PREFIX=documents/

# ── Cloud SQL  (PostgreSQL) ────────────────────────────────────────────────────
# Local dev:  point at the docker-compose postgres container
# Cloud Run:  use Cloud SQL Auth Proxy or the Connector library with instance name
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cognitive_search
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Cloud SQL instance connection name (used by the Connector, ignored in dev)
CLOUD_SQL_INSTANCE=your-project:us-central1:your-instance

# ── Elasticsearch (Elastic Cloud) ─────────────────────────────────────────────
# Local dev: http://localhost:9200  (see docker-compose.yml)
# Production: https://<deployment-id>.es.<region>.gcp.cloud.es.io:443
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_INDEX=cognitive_search_docs

# ── Vertex AI Vector Search ────────────────────────────────────────────────────
# Create index + endpoint in Vertex AI console, then paste resource names here.
# Format: projects/<NUMBER>/locations/<REGION>/indexEndpoints/<ID>
VERTEX_AI_INDEX_ENDPOINT=
# The ID assigned when you deployed the index to the endpoint
VERTEX_AI_DEPLOYED_INDEX_ID=cognitive_search_index
# Format: projects/<NUMBER>/locations/<REGION>/indexes/<ID>
VERTEX_AI_INDEX_NAME=

# ── Gemini Models ─────────────────────────────────────────────────────────────
# Main reasoning / synthesis model
GEMINI_MODEL=gemini-2.5-flash
# Vision model for image / chart understanding
GEMINI_VISION_MODEL=gemini-2.0-flash
# Embedding model (text-embedding-004 gives 768-dim vectors)
VERTEX_EMBEDDING_MODEL=text-embedding-004
VERTEX_EMBEDDING_DIM=768

# ── Ingestion Tuning ──────────────────────────────────────────────────────────
MAX_FILE_MB=50
CHUNK_SIZE=500
CHUNK_OVERLAP=50
BATCH_SIZE=32

# ── Search Tuning ─────────────────────────────────────────────────────────────
DEFAULT_TOP_K=5
# RRF constant – larger softens rank penalty (60 is the standard)
RRF_K=60
